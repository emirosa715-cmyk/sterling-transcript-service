<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      font-family: Verdana, sans-serif;
      font-size: 10pt;
      margin: 40px;
      color: #000;
    }

    .header {
      text-align: center;
      margin-bottom: 20px;
    }

    .header img {
      width: 140px;
      margin-bottom: 10px;
    }

    .title {
      font-size: 18pt;
      font-weight: bold;
      margin-top: 5px;
    }

    .subtitle {
      font-size: 12pt;
      margin-top: -5px;
    }

    .section-title {
      font-weight: bold;
      margin-top: 25px;
      margin-bottom: 8px;
      font-size: 11pt;
      border-bottom: 1px solid #000;
      padding-bottom: 3px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    table th, table td {
      border: 1px solid #000;
      padding: 6px;
      font-size: 10pt;
    }

    .footer {
      margin-top: 40px;
      text-align: center;
      font-style: italic;
      font-size: 10pt;
    }
  </style>
</head>

<body>

  <div class="header">
    <img src="/Sterling Logo.jpg" alt="Sterling Academy Logo">
    <div class="title">Sterling Academy</div>
    <div class="subtitle">Official Transcript</div>
  </div>

  <div class="section-title">Student Information</div>
  <table>
    <tr>
      <th>Name</th>
      <td><%= studentName %></td>
    </tr>
    <tr>
      <th>Years Attended</th>
      <td><%= years %></td>
    </tr>
  </table>

  <div class="section-title">Coursework</div>
  <table>
    <tr>
      <th>Course</th>
      <th>Grade</th>
      <th>Credits</th>
    </tr>
    <tr>
      <td>Sample Course</td>
      <td>A</td>
      <td>1.0</td>
    </tr>
  </table>

  <div class="footer">
    I certify and affirm that this is the official transcript and academic record of
    <%= studentName %>, reflecting coursework completed at Sterling Academy during the
    <%= years %> academic years.
    <br><br>
    <%= registrar %>, Registrar
  </div>

</body>
</html>
